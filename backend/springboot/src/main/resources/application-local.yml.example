spring:
  datasource:
    # DB 계정은 루트 .env의 MYSQL_* 와 동일하게 맞춥니다 (복사 후 자리표시자를 실제 값으로 변경).
    url: jdbc:mysql://localhost:3306/jwt_sample
    username: your_mysql_user
    password: your_mysql_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
    open-in-view: false
    properties:
      hibernate:
        format_sql: true
  data:
    redis:
      host: localhost
      port: 6379

app:
  jwt:
    # 복사 후 32자 이상 임의 문자열로 변경 (Git 커밋 금지)
    secret: your-jwt-secret-at-least-32-characters
    access-expiration: 900000
    refresh-expiration: 604800000
  refresh-token:
    # 복사 후 임의 문자열로 변경 (Git 커밋 금지)
    pepper: your-refresh-token-pepper
  cookie:
    name: user_refresh_token
    # 운영과 동일하게 true 권장 — localhost/127.0.0.1은 브라우저가 HTTP에서도 Secure 쿠키 허용
    # LAN IP(예: http://192.168.x.x)로 접속할 때만 false로 낮추기
    secure: true
    same-site: Strict
    # path: 브라우저가 이 경로로 시작하는 요청에만 쿠키를 자동 첨부한다.
    # 브라우저는 쿠키를 (name + domain + path) 조합으로 식별하므로,
    # 이름이 같아도 path가 다르면 별개의 쿠키로 취급된다.
    # → path=/api/auth  이면 /api/auth/refresh 에만 전송, /api/admin/auth/refresh 에는 미전송.
    path: /api/auth
  admin:
    cookie:
      # name: 사용자 쿠키(user_refresh_token)와 이름을 다르게 설정하면
      # path가 실수로 겹치더라도 충돌하지 않는 추가 안전망(Defense in Depth)이 된다.
      # 단, 운영 중인 서비스에서 name을 바꾸면 기존 사용자 전원이 로그아웃되므로
      # 이미 라이브된 서비스라면 path 분리만으로도 충돌 문제를 해결할 수 있다.
      name: admin_refresh_token
      secure: true
      same-site: Strict
      # path=/api/admin/auth 이면 /api/admin/auth/refresh 에만 전송, /api/auth/refresh 에는 미전송.
      path: /api/admin/auth
  cors:
    allowed-origins:
      - http://localhost:5173
      - http://127.0.0.1:5173
