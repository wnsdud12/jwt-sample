# Docker Compose 전용 (Spring Boot는 application-local.yml 사용)
# cp .env.example .env 후 아래 자리표시자를 본인 환경 값으로 바꾸세요.
# .example 파일에는 실제 비밀번호를 넣지 않습니다.

# MySQL
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=jwt_sample
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password

# Redis
REDIS_PORT=6379
